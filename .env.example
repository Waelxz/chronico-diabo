# ─────────── LLM ───────────
# Get one (free) at https://openrouter.ai/keys — no card required.
OPENROUTER_API_KEY="sk-or-v1-..."
OPENROUTER_BASE_URL="https://openrouter.ai/api/v1"
# Free-tier models (rotate if one is rate-limited upstream):
#   openai/gpt-oss-120b:free               (default — solid FR, generous context)
#   qwen/qwen3-next-80b-a3b-instruct:free  (262k ctx, MoE)
#   meta-llama/llama-3.3-70b-instruct:free (often rate-limited but high quality)
#   nousresearch/hermes-3-llama-3.1-405b:free
#   z-ai/glm-4.5-air:free
OPENROUTER_MODEL="openai/gpt-oss-120b:free"

# ─────────── HuggingFace (sentiment + embeddings) ───────────
# Get one (free) at https://huggingface.co/settings/tokens — Read scope is enough.
HUGGINGFACE_ACCESS_TOKEN="hf_..."

# ─────────── MongoDB Atlas (sprint 1 onwards) ───────────
# Free M0 cluster — https://cloud.mongodb.com (no card)
# Format: mongodb+srv://<user>:<pwd>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=""
MONGODB_DB="chronico_diabo"

# ─────────── App ───────────
APP_URL="http://localhost:3000"
